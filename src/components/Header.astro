---
import { SITE } from '../lib/constants';

const nav = [
  { label: 'Cities', href: '/cities' },
  { label: 'Blog', href: '/blog' },
  { label: 'Local News', href: '/news' },
  { label: 'Our Agents', href: '/agents' },
  { label: 'About', href: '/about' },
];

const pathname = Astro.url.pathname;
---

<header class="bg-white border-b border-slate-100 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex flex-col leading-tight">
        <span class="text-lg font-bold text-[#1a3a2a]">Grand Rapids MN Living</span>
        <span class="text-xs text-slate-500">Pemberton Real Estate</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        {nav.map(item => (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors ${
              pathname.startsWith(item.href)
                ? 'text-[#1a3a2a] font-semibold'
                : 'text-slate-600 hover:text-[#1a3a2a]'
            }`}
          >
            {item.label}
          </a>
        ))}
        <a href="/contact" class="bg-[#1a3a2a] text-[#f5f0e8] px-4 py-2 rounded-md text-sm font-semibold hover:bg-[#2d5a3d] transition-colors">
          Contact Us
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-slate-600 hover:text-[#1a3a2a]"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-slate-100 pt-3">
      {nav.map(item => (
        <a href={item.href} class="block py-2 text-sm font-medium text-slate-700 hover:text-[#1a3a2a]">
          {item.label}
        </a>
      ))}
      <a href="/contact" class="block mt-3 bg-[#1a3a2a] text-[#f5f0e8] px-4 py-2 rounded-md text-sm font-semibold text-center">
        Contact Us
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
