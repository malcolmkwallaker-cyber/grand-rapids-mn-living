---
import { SITE } from '../lib/constants';

const nav = [
  { label: 'Cities', href: '/cities' },
  { label: 'Lakes', href: '/lakes' },
  { label: 'Guides', href: '/guides' },
  { label: 'Blog', href: '/blog' },
  { label: 'Local News', href: '/news' },
  { label: 'Our Agents', href: '/agents' },
  { label: 'About', href: '/about' },
];

const pathname = Astro.url.pathname;
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[68px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="Grand Rapids MN Living — Home">
        <svg class="w-6 h-6 text-[#c9973a] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <div class="flex flex-col leading-tight">
          <span class="text-[16px] font-bold text-[#1e3a5f] tracking-tight">
            Grand Rapids MN
          </span>
          <span class="text-[10px] text-[#c9973a] font-semibold uppercase tracking-widest">
            Living &amp; Real Estate
          </span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="Main navigation">
        {nav.map(item => {
          const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`px-3.5 py-2 rounded-md text-sm font-medium transition-all duration-150 ${
                isActive
                  ? 'text-[#1e3a5f] bg-blue-50'
                  : 'text-slate-600 hover:text-[#1e3a5f] hover:bg-slate-50'
              }`}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
        <a
          href="/contact"
          class="ml-3 bg-[#c9973a] text-white px-5 py-2 rounded-md text-sm font-semibold hover:bg-[#b8832e] transition-all duration-150"
        >
          Contact Us
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-slate-600 hover:text-[#1e3a5f] hover:bg-slate-50 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate-100 bg-white"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-3 space-y-1">
      {nav.map(item => {
        const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`block px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
              isActive
                ? 'text-[#1e3a5f] bg-blue-50 font-semibold'
                : 'text-slate-700 hover:text-[#1e3a5f] hover:bg-slate-50'
            }`}
          >
            {item.label}
          </a>
        );
      })}
      <div class="pt-2 pb-1">
        <a
          href="/contact"
          class="block bg-[#c9973a] text-white px-4 py-3 rounded-md text-sm font-semibold text-center hover:bg-[#b8832e] transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const header = document.getElementById('site-header');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  });
</script>
