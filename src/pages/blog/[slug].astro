---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', p => !p.data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const schema = {
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@type': 'Organization', name: 'Pemberton Real Estate' },
  datePublished: post.data.pubDate.toISOString(),
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  type="article"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <a href="/blog" class="text-sm text-slate-400 hover:text-[#1a3a2a] mb-6 inline-block">← Back to Blog</a>

    {post.data.city && (
      <span class="text-xs font-semibold uppercase tracking-wider text-[#c9973a]">{post.data.city}</span>
    )}
    <h1 class="text-4xl font-bold text-[#1a3a2a] mt-2 mb-3 leading-tight">{post.data.title}</h1>
    <p class="text-slate-500 text-sm mb-2">
      By <strong>{post.data.author}</strong> · Pemberton Real Estate ·{' '}
      {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
    </p>

    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {post.data.tags.map(tag => (
          <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">{tag}</span>
        ))}
      </div>
    )}

    <div class="prose prose-slate max-w-none prose-headings:text-[#1a3a2a] prose-a:text-[#2d5a3d]">
      <Content />
    </div>

    <!-- Agent CTA -->
    <div class="mt-12 bg-[#f5f0e8] rounded-xl p-6 text-center">
      <h3 class="font-bold text-[#1a3a2a] text-xl mb-2">Have Questions? We're Here to Help.</h3>
      <p class="text-slate-600 text-sm mb-4">
        Malcolm Wallaker and Bridger Hopkins are Grand Rapids MN's top REALTORS® at Pemberton Real Estate.
      </p>
      <a href="/contact" class="bg-[#1a3a2a] text-[#f5f0e8] px-6 py-2 rounded-md font-semibold text-sm hover:bg-[#2d5a3d] transition-colors">
        Contact Our Team
      </a>
    </div>
  </div>
</Layout>
