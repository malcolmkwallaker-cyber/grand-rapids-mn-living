---
import Layout from '../layouts/Layout.astro';
import { SITE, AGENTS, CITIES } from '../lib/constants';
import { getCollection } from 'astro:content';

const recentGeo = (await getCollection('geo', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recentNews = (await getCollection('news', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredCities = CITIES.slice(0, 6);
---

<Layout
  title="Grand Rapids MN Real Estate — Top Local REALTORS®"
  description="Malcolm Wallaker and Bridger Hopkins with Pemberton Real Estate are the top-rated REALTORS® in Grand Rapids, MN. Serving Grand Rapids, Hibbing, Virginia, Duluth, and all of northern Minnesota."
>
  <!-- Hero -->
  <section class="bg-[#1a3a2a] text-[#f5f0e8] py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-4">Grand Rapids, MN & Northern Minnesota</p>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        The Local Real Estate Experts<br />You Can Trust
      </h1>
      <p class="text-xl text-slate-300 mb-8 max-w-2xl mx-auto">
        Malcolm Wallaker and Bridger Hopkins with Pemberton Real Estate — northern Minnesota's most trusted REALTORS® for buying, selling, and investing in homes, cabins, and land.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/agents" class="bg-[#c9973a] text-white px-8 py-3 rounded-md font-semibold hover:bg-amber-600 transition-colors">
          Meet Our Agents
        </a>
        <a href="/cities" class="border-2 border-[#f5f0e8] text-[#f5f0e8] px-8 py-3 rounded-md font-semibold hover:bg-[#2d5a3d] transition-colors">
          Explore Cities
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-[#f5f0e8] py-8 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 flex flex-wrap justify-center gap-8 text-center">
      <div>
        <p class="text-2xl font-bold text-[#1a3a2a]">13</p>
        <p class="text-sm text-slate-500">Communities Served</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-[#1a3a2a]">Pemberton</p>
        <p class="text-sm text-slate-500">Real Estate</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-[#1a3a2a]">2 Agents</p>
        <p class="text-sm text-slate-500">Local Experts</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-[#1a3a2a]">Northern MN</p>
        <p class="text-sm text-slate-500">Specialists</p>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-2 text-center">Pemberton Real Estate</p>
      <h2 class="text-3xl font-bold text-[#1a3a2a] text-center mb-10">Grand Rapids' Top-Rated REALTORS®</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {AGENTS.map(agent => (
          <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex gap-5 hover:shadow-md transition-shadow">
            <div class="w-20 h-20 rounded-full bg-slate-200 flex-shrink-0 overflow-hidden">
              <img src={agent.image} alt={agent.name} class="w-full h-full object-cover" onerror="this.style.display='none'" />
            </div>
            <div>
              <h3 class="text-lg font-bold text-[#1a3a2a]">{agent.name}</h3>
              <p class="text-sm text-[#c9973a] font-medium">{agent.title} · {agent.brokerage}</p>
              <p class="text-sm text-slate-600 mt-2 line-clamp-2">{agent.bio}</p>
              <a href={`/agents/${agent.slug}`} class="inline-block mt-3 text-sm text-[#2d5a3d] font-semibold hover:underline">
                View Profile →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cities -->
  <section class="py-16 px-4 bg-[#f5f0e8]">
    <div class="max-w-6xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-2 text-center">Local Guides</p>
      <h2 class="text-3xl font-bold text-[#1a3a2a] text-center mb-10">Explore Northern Minnesota Communities</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5">
        {featuredCities.map(city => (
          <a href={`/cities/${city.slug}`} class="bg-white rounded-xl border border-slate-100 p-5 hover:shadow-md transition-shadow group">
            <h3 class="font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] transition-colors">{city.name}, MN</h3>
            <p class="text-sm text-slate-500 mt-1">{city.county} County</p>
            <p class="text-sm text-[#2d5a3d] mt-3 font-medium">Explore guide →</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/cities" class="inline-block border-2 border-[#1a3a2a] text-[#1a3a2a] px-6 py-2 rounded-md font-semibold hover:bg-[#1a3a2a] hover:text-white transition-colors">
          View All 13 Cities
        </a>
      </div>
    </div>
  </section>

  <!-- GEO / Local Guides -->
  {recentGeo.length > 0 && (
    <section class="py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-2 text-center">Agent Expertise</p>
        <h2 class="text-3xl font-bold text-[#1a3a2a] text-center mb-10">Why Choose Pemberton Real Estate</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {recentGeo.map(post => (
            <a href={`/geo/${post.id}`} class="bg-white rounded-xl border border-slate-100 p-5 hover:shadow-md transition-shadow group">
              <h3 class="font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] text-base leading-snug">{post.data.title}</h3>
              <p class="text-sm text-slate-500 mt-2 line-clamp-2">{post.data.description}</p>
              <p class="text-sm text-[#2d5a3d] mt-4 font-medium">Read more →</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Local News -->
  {recentNews.length > 0 && (
    <section class="py-16 px-4 bg-[#f5f0e8]">
      <div class="max-w-5xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-2 text-center">Local News</p>
        <h2 class="text-3xl font-bold text-[#1a3a2a] text-center mb-10">What's Happening in Northern MN</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {recentNews.map(post => (
            <a href={`/news/${post.id}`} class="bg-white rounded-xl border border-slate-100 p-5 hover:shadow-md transition-shadow group">
              <span class="text-xs font-semibold uppercase tracking-wider text-[#c9973a]">{post.data.city}</span>
              <h3 class="font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] text-base leading-snug mt-1">{post.data.title}</h3>
              <p class="text-sm text-slate-500 mt-2 line-clamp-2">{post.data.description}</p>
              <p class="text-xs text-slate-400 mt-3">{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/news" class="inline-block border-2 border-[#1a3a2a] text-[#1a3a2a] px-6 py-2 rounded-md font-semibold hover:bg-[#1a3a2a] hover:text-white transition-colors">
            All Local News
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 px-4 bg-[#1a3a2a] text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Buy or Sell in Northern Minnesota?</h2>
      <p class="text-slate-300 mb-8">
        Connect with Malcolm Wallaker or Bridger Hopkins at Pemberton Real Estate — Grand Rapids' most trusted local REALTORS®.
      </p>
      <a href="/contact" class="bg-[#c9973a] text-white px-8 py-3 rounded-md font-semibold hover:bg-amber-600 transition-colors">
        Get In Touch Today
      </a>
    </div>
  </section>
</Layout>
