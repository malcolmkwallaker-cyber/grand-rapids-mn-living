---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news', p => !p.data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const schema = {
  '@type': 'NewsArticle',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  publisher: { '@type': 'Organization', name: 'Pemberton Real Estate' },
  about: { '@type': 'City', name: post.data.city, containedInPlace: { '@type': 'State', name: 'Minnesota' } },
};
---

<Layout
  title={`${post.data.title} — ${post.data.city}, MN`}
  description={post.data.description}
  type="article"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <a href="/news" class="text-sm text-slate-400 hover:text-[#1a3a2a] mb-6 inline-block">← Local News</a>

    <span class="text-xs font-semibold uppercase tracking-wider text-[#c9973a]">{post.data.city}, MN</span>
    <h1 class="text-3xl font-bold text-[#1a3a2a] mt-2 mb-3 leading-tight">{post.data.title}</h1>

    <div class="flex items-center gap-4 mb-8">
      <span class="text-xs text-slate-400">
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </span>
      {post.data.source && post.data.sourceUrl && (
        <a href={post.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-xs text-[#2d5a3d] hover:underline">
          Source: {post.data.source} →
        </a>
      )}
      {post.data.source && !post.data.sourceUrl && (
        <span class="text-xs text-slate-400">Source: {post.data.source}</span>
      )}
    </div>

    <div class="prose prose-slate max-w-none prose-headings:text-[#1a3a2a] prose-a:text-[#2d5a3d]">
      <Content />
    </div>

    <div class="mt-10 p-5 bg-[#f5f0e8] rounded-xl">
      <p class="text-sm text-slate-600">
        <strong class="text-[#1a3a2a]">Interested in real estate in {post.data.city}?</strong>{' '}
        Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate are the local experts.{' '}
        <a href="/contact" class="text-[#2d5a3d] font-semibold hover:underline">Get in touch →</a>
      </p>
    </div>
  </div>
</Layout>
