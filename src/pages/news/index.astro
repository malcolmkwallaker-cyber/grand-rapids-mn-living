---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CITIES } from '../../lib/constants';

const allNews = (await getCollection('news', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const cityParam = Astro.url.searchParams.get('city');
const posts = cityParam
  ? allNews.filter(p => p.data.city.toLowerCase() === cityParam.toLowerCase())
  : allNews;
---

<Layout
  title="Local News — Northern Minnesota"
  description="Local news from Grand Rapids, Hibbing, Virginia, Duluth, and surrounding northern Minnesota communities. Updated twice weekly by Pemberton Real Estate."
>
  <section class="bg-[#1a3a2a] py-14 px-4 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-3">Community Updates</p>
    <h1 class="text-4xl font-bold text-white mb-4">Local News</h1>
    <p class="text-slate-300 max-w-xl mx-auto">
      Staying on top of what's happening across northern Minnesota — real estate, development, community events, and more.
    </p>
  </section>

  <!-- City Filter -->
  <section class="py-6 px-4 bg-[#f5f0e8] border-b border-slate-200">
    <div class="max-w-5xl mx-auto flex flex-wrap gap-2 justify-center">
      <a
        href="/news"
        class={`text-sm px-3 py-1 rounded-full border font-medium transition-colors ${
          !cityParam ? 'bg-[#1a3a2a] text-white border-[#1a3a2a]' : 'border-slate-300 text-slate-600 hover:border-[#1a3a2a] hover:text-[#1a3a2a]'
        }`}
      >
        All Cities
      </a>
      {CITIES.map(city => (
        <a
          href={`/news?city=${encodeURIComponent(city.name)}`}
          class={`text-sm px-3 py-1 rounded-full border font-medium transition-colors ${
            cityParam === city.name ? 'bg-[#1a3a2a] text-white border-[#1a3a2a]' : 'border-slate-300 text-slate-600 hover:border-[#1a3a2a] hover:text-[#1a3a2a]'
          }`}
        >
          {city.name}
        </a>
      ))}
    </div>
  </section>

  <section class="py-12 px-4">
    <div class="max-w-5xl mx-auto">
      {posts.length === 0 && (
        <p class="text-center text-slate-500 py-12">No news stories yet. Check back Monday or Thursday.</p>
      )}
      <div class="grid md:grid-cols-2 gap-6">
        {posts.map(post => (
          <a href={`/news/${post.id}`} class="bg-white rounded-xl border border-slate-100 p-5 hover:shadow-md transition-shadow group">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold uppercase tracking-wider text-[#c9973a]">{post.data.city}</span>
              <span class="text-xs text-slate-400">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </div>
            <h2 class="font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] leading-snug">{post.data.title}</h2>
            <p class="text-sm text-slate-500 mt-2 line-clamp-2">{post.data.description}</p>
            {post.data.source && (
              <p class="text-xs text-slate-400 mt-3">Source: {post.data.source}</p>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
