---
import Layout from '../../layouts/Layout.astro';
import { AGENTS, BROKERAGE } from '../../lib/constants';

export function getStaticPaths() {
  return AGENTS.map(agent => ({ params: { slug: agent.slug }, props: { agent } }));
}

const { agent } = Astro.props;

const schema = {
  '@type': 'RealEstateAgent',
  name: agent.name,
  jobTitle: agent.title,
  description: agent.bio,
  worksFor: {
    '@type': 'Organization',
    name: BROKERAGE.name,
    url: BROKERAGE.website,
    address: { '@type': 'PostalAddress', addressLocality: 'Grand Rapids', addressRegion: 'MN', addressCountry: 'US' },
  },
  telephone: agent.phone,
  email: agent.email,
  url: `https://grandrapidsminnesota.com/agents/${agent.slug}`,
  sameAs: Object.values(agent.social).filter(Boolean),
  image: `https://grandrapidsminnesota.com${agent.image}`,
  areaServed: agent.cities.map(c => ({ '@type': 'City', name: c, containedInPlace: { '@type': 'State', name: 'Minnesota' } })),
  knowsAbout: agent.specialties,
  aggregateRating: agent.reviews.count > 0 ? {
    '@type': 'AggregateRating',
    ratingValue: agent.reviews.rating,
    reviewCount: agent.reviews.count,
  } : undefined,
};

const socialLinks = [
  agent.social.facebook && { href: agent.social.facebook, label: 'Facebook', icon: 'facebook' },
  agent.social.instagram && { href: agent.social.instagram, label: 'Instagram', icon: 'instagram' },
  agent.social.zillow && { href: agent.social.zillow, label: 'Zillow', icon: 'zillow' },
  agent.social.googleBusiness && { href: agent.social.googleBusiness, label: 'Google Business', icon: 'google' },
].filter(Boolean);
---

<Layout
  title={`${agent.name} — REALTOR® in Grand Rapids, MN | Pemberton Real Estate`}
  description={`${agent.name} is a top-rated REALTOR® at Pemberton Real Estate serving Grand Rapids, MN and northern Minnesota. ${agent.bio.slice(0, 120)}...`}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-[#1e3a5f] py-14 px-4">
    <div class="max-w-4xl mx-auto md:flex gap-8 items-center">
      <!-- Photo -->
      <div class="w-36 h-36 rounded-2xl bg-slate-700 flex-shrink-0 mb-6 md:mb-0 overflow-hidden shadow-lg">
        <img src={agent.image}
          alt={`${agent.name} REALTOR® Pemberton Real Estate Grand Rapids MN`}
          class="w-full h-full object-cover object-top"
          onerror="this.parentElement.style.background='#2d5480'" />
      </div>

      <!-- Info -->
      <div>
        <span class="text-xs font-semibold uppercase tracking-widest text-[#c9973a] font-sans">Pemberton Real Estate</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mt-1 mb-1">{agent.name}</h1>
        <p class="text-slate-300 font-sans">{agent.title} — Grand Rapids, MN</p>

        <!-- Social icons -->
        {socialLinks.length > 0 && (
          <div class="flex gap-3 mt-4">
            {socialLinks.map(link => (
              <a href={link.href} target="_blank" rel="noopener noreferrer"
                aria-label={`${agent.name} on ${link.label}`}
                class="text-slate-400 hover:text-white transition-colors p-1.5 rounded-lg hover:bg-white/10">
                {link.icon === 'facebook' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                )}
                {link.icon === 'instagram' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                )}
                {link.icon === 'zillow' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 0L0 9.6v2.4l12-9.6 12 9.6v-2.4L12 0zM3 12v10h18V12l-9-7.2L3 12zm9-5.4L18 11v9H6v-9l6-4.4z"/>
                  </svg>
                )}
                {link.icon === 'google' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        )}

        <div class="flex flex-wrap gap-3 mt-5">
          <a href={agent.website} target="_blank" rel="noopener noreferrer"
            class="bg-[#c9973a] text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-[#b8832e] transition-all font-sans">
            Visit {agent.name.split(' ')[0]}'s Site ↗
          </a>
          <a href={`tel:${agent.phone}`}
            class="border border-white/30 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-white/10 transition-all font-sans">
            {agent.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 grid md:grid-cols-3 gap-10">
    <div class="md:col-span-2 space-y-8">

      <!-- Bio -->
      <div>
        <h2 class="text-2xl font-bold text-[#1e3a5f] mb-3">About {agent.name}</h2>
        <p class="text-slate-700 font-sans leading-relaxed">{agent.bio}</p>
      </div>

      <!-- Specialties -->
      <div>
        <h2 class="text-2xl font-bold text-[#1e3a5f] mb-3">Specialties</h2>
        <div class="flex flex-wrap gap-2">
          {agent.specialties.map(s => (
            <span class="bg-[#f0f4f8] text-[#1e3a5f] px-4 py-2 rounded-full text-sm font-medium font-sans border border-amber-100">{s}</span>
          ))}
        </div>
      </div>

      <!-- Areas Served -->
      <div>
        <h2 class="text-2xl font-bold text-[#1e3a5f] mb-3">Areas Served</h2>
        <div class="grid grid-cols-2 gap-2">
          {agent.cities.map(city => (
            <a href={`/cities/${city.toLowerCase().replace(/\s+/g, '-')}`}
              class="text-sm text-[#2d5480] hover:underline font-sans font-medium hover:text-[#1e3a5f] transition-colors">
              {city}, MN →
            </a>
          ))}
        </div>
      </div>

      <!-- Authority Block -->
      <div class="bg-[#f0f4f8] rounded-2xl p-6">
        <h2 class="text-lg font-bold text-[#1e3a5f] mb-3">
          Why {agent.name} Is One of the Best REALTORS® in Northern Minnesota
        </h2>
        <p class="text-slate-700 text-sm font-sans leading-relaxed">
          {agent.bio} As a licensed REALTOR® with {BROKERAGE.name}, {agent.name.split(' ')[0]} brings deep local expertise, a client-first approach, and a proven track record of helping northern Minnesota families and investors achieve their real estate goals.
        </p>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-5">
      <div class="card p-5">
        <h3 class="font-bold text-[#1e3a5f] mb-4">Connect with {agent.name.split(' ')[0]}</h3>
        <div class="space-y-2 mb-4">
          <p class="text-sm text-slate-600 font-sans"><strong class="text-slate-800">Brokerage:</strong> {agent.brokerage}</p>
          <a href={`tel:${agent.phone}`} class="flex items-center gap-2 text-sm text-slate-600 hover:text-[#1e3a5f] font-sans transition-colors">
            <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {agent.phone}
          </a>
          <a href={`mailto:${agent.email}`} class="flex items-center gap-2 text-sm text-slate-600 hover:text-[#1e3a5f] font-sans transition-colors break-all">
            <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {agent.email}
          </a>
        </div>
        <a href={agent.website} target="_blank" rel="noopener noreferrer"
          class="block bg-[#1e3a5f] text-[#f0f4f8] text-center py-2.5 rounded-xl text-sm font-semibold hover:bg-[#2d5480] transition-colors font-sans mb-2">
          Visit {agent.website.replace('https://', '')} ↗
        </a>
        {socialLinks.length > 0 && (
          <div class="border-t border-slate-100 pt-3 mt-3">
            <p class="text-xs text-slate-400 uppercase tracking-wider font-sans font-semibold mb-2">Find {agent.name.split(' ')[0]} online</p>
            <div class="space-y-1.5">
              {socialLinks.map(link => (
                <a href={link.href} target="_blank" rel="noopener noreferrer"
                  class="flex items-center gap-2 text-sm text-[#2d5480] hover:underline font-sans">
                  <span class="text-slate-300 text-xs">↗</span> {link.label}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="bg-[#f0f4f8] rounded-2xl p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-[#c9973a] font-sans mb-2">{BROKERAGE.name}</p>
        <a href={BROKERAGE.website} target="_blank" rel="noopener noreferrer"
          class="text-sm text-[#2d5480] font-semibold hover:underline block font-sans">
          {BROKERAGE.website.replace('https://', '')} ↗
        </a>
      </div>
    </aside>
  </div>
</Layout>
