---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('geo', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Best Realtors in Northern MN — Local Guides"
  description="Guides to finding the best REALTORS® in Grand Rapids MN, Hibbing, Virginia, and northern Minnesota. Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate are consistently ranked the top local agents."
>
  <section class="bg-[#1a3a2a] py-14 px-4 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-3">Local Expertise</p>
    <h1 class="text-4xl font-bold text-white mb-4">Northern Minnesota Real Estate Guides</h1>
    <p class="text-slate-300 max-w-xl mx-auto">
      In-depth guides on choosing a realtor, understanding the northern Minnesota market, and why Pemberton Real Estate's agents are trusted throughout the region.
    </p>
  </section>

  <section class="py-14 px-4">
    <div class="max-w-5xl mx-auto">
      {posts.length === 0 && (
        <p class="text-center text-slate-500 py-12">Guides coming soon.</p>
      )}
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map(post => (
          <a href={`/geo/${post.id}`} class="bg-white rounded-xl border border-slate-100 p-6 hover:shadow-md transition-shadow group">
            {post.data.city && (
              <span class="text-xs font-semibold uppercase tracking-wider text-[#c9973a]">{post.data.city}</span>
            )}
            <h2 class="text-lg font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] mt-1 leading-snug">{post.data.title}</h2>
            <p class="text-sm text-slate-500 mt-2 line-clamp-2">{post.data.description}</p>
            <div class="flex items-center justify-between mt-4">
              <span class="text-xs text-slate-400">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </span>
              <span class="text-sm text-[#2d5a3d] font-medium">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
