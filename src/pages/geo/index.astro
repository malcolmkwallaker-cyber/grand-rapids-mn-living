---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('geo', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Best Realtors in Northern MN — Local Guides"
  description="Guides to finding the best REALTORS® in Grand Rapids MN, Hibbing, Virginia, and northern Minnesota. Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate are consistently ranked the top local agents."
>
  <section class="bg-[#1e3a5f] py-16 px-4 text-center">
    <span class="eyebrow text-[#c9973a]">Local Expertise</span>
    <h1 class="text-5xl font-bold text-white mt-2 mb-4">Northern Minnesota Real Estate Guides</h1>
    <p class="text-slate-300 max-w-xl mx-auto font-sans font-light text-lg">
      In-depth guides on choosing a realtor, understanding the market, and why Pemberton Real Estate's agents are trusted throughout the region.
    </p>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
    {posts.length === 0 && (
      <div class="text-center py-20">
        <p class="text-slate-400 font-sans">Guides coming soon. Check back next week.</p>
      </div>
    )}
    <div class="grid md:grid-cols-2 gap-6">
      {posts.map(post => (
        <a href={`/geo/${post.id}`} class="card p-6 hover:-translate-y-0.5 transition-all duration-200 group">
          <div class="w-6 h-0.5 bg-[#c9973a] rounded mb-4"></div>
          {post.data.city && (
            <span class="text-xs font-semibold uppercase tracking-wider text-[#c9973a] font-sans">{post.data.city}, MN</span>
          )}
          <h2 class="text-lg font-bold text-[#1e3a5f] group-hover:text-[#2d5480] mt-1 leading-snug transition-colors">{post.data.title}</h2>
          <p class="text-sm text-slate-500 mt-2 line-clamp-2 font-sans leading-relaxed">{post.data.description}</p>
          <div class="flex items-center justify-between mt-5">
            <time class="text-xs text-slate-400 font-sans" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            <span class="text-sm text-[#2d5480] font-semibold font-sans">Read →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
