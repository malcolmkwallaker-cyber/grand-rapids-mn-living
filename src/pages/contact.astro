---
import Layout from '../layouts/Layout.astro';
import { AGENTS, BROKERAGE } from '../lib/constants';
---

<Layout
  title="Contact Pemberton Real Estate — Grand Rapids, MN"
  description="Contact Malcolm Wallaker or Bridger Hopkins at Pemberton Real Estate in Grand Rapids, MN. We're the local experts for buying, selling, and investing in northern Minnesota real estate."
>
  <section class="bg-[#1a3a2a] py-14 px-4 text-center">
    <h1 class="text-4xl font-bold text-white mb-4">Get In Touch</h1>
    <p class="text-slate-300 max-w-xl mx-auto">
      Ready to buy, sell, or just have questions about northern Minnesota real estate? We're here to help.
    </p>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-14 grid md:grid-cols-2 gap-12">
    <!-- Contact Form -->
    <div>
      <h2 class="text-2xl font-bold text-[#1a3a2a] mb-6">Send Us a Message</h2>
      <form name="contact" method="POST" data-netlify="true" class="space-y-5">
        <input type="hidden" name="form-name" value="contact" />
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Name *</label>
          <input type="text" name="name" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#1a3a2a]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email *</label>
          <input type="email" name="email" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#1a3a2a]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Phone</label>
          <input type="tel" name="phone" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#1a3a2a]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">City of Interest</label>
          <input type="text" name="city" placeholder="e.g. Grand Rapids, Hibbing..." class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#1a3a2a]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Message *</label>
          <textarea name="message" required rows="4" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#1a3a2a]"></textarea>
        </div>
        <button type="submit" class="w-full bg-[#1a3a2a] text-[#f5f0e8] py-3 rounded-md font-semibold hover:bg-[#2d5a3d] transition-colors">
          Send Message
        </button>
      </form>
    </div>

    <!-- Agent Contacts -->
    <div class="space-y-6">
      <h2 class="text-2xl font-bold text-[#1a3a2a]">Reach Us Directly</h2>
      {AGENTS.map(agent => (
        <div class="bg-[#f5f0e8] rounded-xl p-5">
          <h3 class="font-bold text-[#1a3a2a]">{agent.name}</h3>
          <p class="text-sm text-[#c9973a] font-medium">{agent.title} · {agent.brokerage}</p>
          <p class="text-sm text-slate-600 mt-2">{agent.phone}</p>
          <p class="text-sm text-slate-600">{agent.email}</p>
          <p class="text-sm text-slate-500 mt-1 mb-3">Serving: {agent.cities.slice(0, 4).join(', ')}{agent.cities.length > 4 ? ` +${agent.cities.length - 4} more` : ''}</p>
          <a href={agent.website} target="_blank" rel="noopener noreferrer"
            class="text-sm text-[#2d5a3d] font-semibold hover:underline block mb-2">
            {agent.website.replace('https://', '')} ↗
          </a>
          <div class="flex gap-3">
            {agent.social.facebook && (
              <a href={agent.social.facebook} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-500 hover:text-[#1a3a2a]">Facebook</a>
            )}
            {agent.social.instagram && (
              <a href={agent.social.instagram} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-500 hover:text-[#1a3a2a]">Instagram</a>
            )}
            {agent.social.zillow && (
              <a href={agent.social.zillow} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-500 hover:text-[#1a3a2a]">Zillow</a>
            )}
            {agent.social.googleBusiness && (
              <a href={agent.social.googleBusiness} target="_blank" rel="noopener noreferrer" class="text-xs text-slate-500 hover:text-[#1a3a2a]">Google</a>
            )}
          </div>
        </div>
      ))}
      <div class="bg-white rounded-xl border border-slate-100 p-5">
        <h3 class="font-bold text-[#1a3a2a] mb-1">{BROKERAGE.name}</h3>
        <p class="text-sm text-slate-600">{BROKERAGE.address}</p>
        <p class="text-sm text-slate-600">{BROKERAGE.phone}</p>
        <p class="text-sm text-slate-600 mb-3">{BROKERAGE.email}</p>
        <a href={BROKERAGE.website} target="_blank" rel="noopener noreferrer"
          class="text-sm text-[#2d5a3d] font-semibold hover:underline block mb-2">
          {BROKERAGE.website.replace('https://', '')} ↗
        </a>
        <div class="flex gap-3 mt-2">
          <a href={BROKERAGE.social.facebook} target="_blank" rel="noopener noreferrer"
            class="text-sm text-slate-500 hover:text-[#1a3a2a]">Facebook</a>
          <a href={BROKERAGE.social.instagram} target="_blank" rel="noopener noreferrer"
            class="text-sm text-slate-500 hover:text-[#1a3a2a]">Instagram</a>
        </div>
      </div>
    </div>
  </div>
</Layout>
