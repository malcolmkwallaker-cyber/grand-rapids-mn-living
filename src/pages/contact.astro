---
import Layout from '../layouts/Layout.astro';
import { AGENTS, BROKERAGE } from '../lib/constants';
---

<Layout
  title="Contact Pemberton Real Estate — Grand Rapids, MN"
  description="Contact Malcolm Wallaker or Bridger Hopkins at Pemberton Real Estate in Grand Rapids, MN. We're the local experts for buying, selling, and investing in northern Minnesota real estate."
>
  <!-- Hero -->
  <section class="bg-[#1a3a2a] py-16 px-4 text-center">
    <span class="eyebrow text-[#c9973a]">Pemberton Real Estate</span>
    <h1 class="text-5xl font-bold text-white mt-2 mb-4">Get In Touch</h1>
    <p class="text-slate-300 max-w-xl mx-auto font-sans font-light text-lg">
      Ready to buy, sell, or just have questions about northern Minnesota real estate? We're here to help.
    </p>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14 grid md:grid-cols-2 gap-12">

    <!-- Contact Form -->
    <div>
      <h2 class="text-3xl font-bold text-[#1a3a2a] mb-2">Send Us a Message</h2>
      <p class="text-slate-500 font-sans text-sm mb-7">We'll get back to you within one business day.</p>

      <form name="contact" method="POST" data-netlify="true" class="space-y-5" novalidate>
        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label for="contact-name" class="block text-sm font-semibold text-slate-700 font-sans mb-1.5">Your Name <span class="text-red-400" aria-hidden="true">*</span></label>
          <input type="text" id="contact-name" name="name" required autocomplete="name"
            class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-sans focus:outline-none focus:ring-2 focus:ring-[#1a3a2a] focus:border-transparent transition-all bg-white placeholder-slate-300"
            placeholder="Jane Smith" />
        </div>

        <div>
          <label for="contact-email" class="block text-sm font-semibold text-slate-700 font-sans mb-1.5">Email Address <span class="text-red-400" aria-hidden="true">*</span></label>
          <input type="email" id="contact-email" name="email" required autocomplete="email"
            class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-sans focus:outline-none focus:ring-2 focus:ring-[#1a3a2a] focus:border-transparent transition-all bg-white placeholder-slate-300"
            placeholder="jane@example.com" />
        </div>

        <div>
          <label for="contact-phone" class="block text-sm font-semibold text-slate-700 font-sans mb-1.5">Phone Number</label>
          <input type="tel" id="contact-phone" name="phone" autocomplete="tel"
            class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-sans focus:outline-none focus:ring-2 focus:ring-[#1a3a2a] focus:border-transparent transition-all bg-white placeholder-slate-300"
            placeholder="(218) 555-0100" />
        </div>

        <div>
          <label for="contact-city" class="block text-sm font-semibold text-slate-700 font-sans mb-1.5">City of Interest</label>
          <input type="text" id="contact-city" name="city"
            class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-sans focus:outline-none focus:ring-2 focus:ring-[#1a3a2a] focus:border-transparent transition-all bg-white placeholder-slate-300"
            placeholder="e.g. Grand Rapids, Hibbing..." />
        </div>

        <div>
          <label for="contact-message" class="block text-sm font-semibold text-slate-700 font-sans mb-1.5">Message <span class="text-red-400" aria-hidden="true">*</span></label>
          <textarea id="contact-message" name="message" required rows="4"
            class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm font-sans focus:outline-none focus:ring-2 focus:ring-[#1a3a2a] focus:border-transparent transition-all bg-white placeholder-slate-300 resize-none"
            placeholder="Tell us a bit about what you're looking for..."></textarea>
        </div>

        <button type="submit"
          class="w-full bg-[#1a3a2a] text-[#f5f0e8] py-3.5 rounded-xl font-semibold font-sans hover:bg-[#2d5a3d] transition-all duration-200 text-sm">
          Send Message
        </button>
      </form>
    </div>

    <!-- Agent Contacts -->
    <div class="space-y-5">
      <div>
        <h2 class="text-3xl font-bold text-[#1a3a2a] mb-2">Reach Us Directly</h2>
        <p class="text-slate-500 font-sans text-sm">Prefer to call or email? We're easy to reach.</p>
      </div>

      {AGENTS.map(agent => (
        <div class="card p-5">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 rounded-full bg-slate-100 flex-shrink-0 overflow-hidden">
              <img src={agent.image} alt={agent.name}
                class="w-full h-full object-cover"
                onerror="this.parentElement.style.background='#e8e4dc'" />
            </div>
            <div>
              <h3 class="font-bold text-[#1a3a2a]">{agent.name}</h3>
              <p class="text-xs text-[#c9973a] font-semibold font-sans uppercase tracking-wider">{agent.title} · {agent.brokerage}</p>
            </div>
          </div>

          <div class="space-y-2 mb-4">
            <a href={`tel:${agent.phone}`}
              class="flex items-center gap-2 text-sm text-slate-700 hover:text-[#1a3a2a] font-sans transition-colors">
              <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {agent.phone}
            </a>
            <a href={`mailto:${agent.email}`}
              class="flex items-center gap-2 text-sm text-slate-700 hover:text-[#1a3a2a] font-sans transition-colors">
              <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {agent.email}
            </a>
          </div>

          <p class="text-xs text-slate-400 font-sans mb-3">
            Serving: {agent.cities.slice(0, 4).join(', ')}{agent.cities.length > 4 ? ` +${agent.cities.length - 4} more` : ''}
          </p>

          <a href={agent.website} target="_blank" rel="noopener noreferrer"
            class="text-sm text-[#2d5a3d] font-semibold hover:underline block mb-2 font-sans">
            {agent.website.replace('https://', '')} ↗
          </a>

          <div class="flex gap-3 pt-2 border-t border-slate-100">
            {agent.social.facebook && (
              <a href={agent.social.facebook} target="_blank" rel="noopener noreferrer"
                class="text-xs text-slate-400 hover:text-[#1a3a2a] font-sans transition-colors">Facebook</a>
            )}
            {agent.social.instagram && (
              <a href={agent.social.instagram} target="_blank" rel="noopener noreferrer"
                class="text-xs text-slate-400 hover:text-[#1a3a2a] font-sans transition-colors">Instagram</a>
            )}
            {agent.social.zillow && (
              <a href={agent.social.zillow} target="_blank" rel="noopener noreferrer"
                class="text-xs text-slate-400 hover:text-[#1a3a2a] font-sans transition-colors">Zillow</a>
            )}
            {agent.social.googleBusiness && (
              <a href={agent.social.googleBusiness} target="_blank" rel="noopener noreferrer"
                class="text-xs text-slate-400 hover:text-[#1a3a2a] font-sans transition-colors">Google</a>
            )}
          </div>
        </div>
      ))}

      <div class="bg-[#f5f0e8] rounded-2xl p-5">
        <h3 class="font-bold text-[#1a3a2a] mb-1">{BROKERAGE.name}</h3>
        <p class="text-sm text-slate-600 font-sans">{BROKERAGE.address}</p>
        <a href={BROKERAGE.website} target="_blank" rel="noopener noreferrer"
          class="text-sm text-[#2d5a3d] font-semibold hover:underline block mt-3 font-sans">
          {BROKERAGE.website.replace('https://', '')} ↗
        </a>
        <div class="flex gap-3 mt-2">
          <a href={BROKERAGE.social.facebook} target="_blank" rel="noopener noreferrer"
            class="text-xs text-slate-500 hover:text-[#1a3a2a] font-sans transition-colors">Facebook</a>
          <a href={BROKERAGE.social.instagram} target="_blank" rel="noopener noreferrer"
            class="text-xs text-slate-500 hover:text-[#1a3a2a] font-sans transition-colors">Instagram</a>
        </div>
      </div>
    </div>
  </div>
</Layout>
