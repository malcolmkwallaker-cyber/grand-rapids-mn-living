---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { AGENTS } from '../../lib/constants';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map(city => ({ params: { slug: city.id }, props: { city } }));
}

const { city } = Astro.props;
const { Content } = await render(city);

const cityAgents = AGENTS.filter(a => a.cities.includes(city.data.name));

const schema = {
  '@type': 'WebPage',
  name: `${city.data.name}, MN Real Estate Guide`,
  description: city.data.tagline,
  about: {
    '@type': 'City',
    name: city.data.name,
    containedInPlace: { '@type': 'State', name: 'Minnesota' },
  },
};
---

<Layout
  title={`${city.data.name}, MN — Real Estate & Local Guide`}
  description={`${city.data.tagline}. Local real estate insights, school info, and community guides from Pemberton Real Estate's Malcolm Wallaker and Bridger Hopkins.`}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-[#1a3a2a] py-14 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/cities" class="text-sm text-slate-400 hover:text-white mb-4 inline-block">← All Cities</a>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-3">{city.data.name}, MN</h1>
      <p class="text-xl text-slate-300">{city.data.tagline}</p>

      <!-- Stats -->
      <div class="flex flex-wrap gap-6 mt-8">
        <div class="bg-[#2d5a3d] rounded-lg px-4 py-3">
          <p class="text-xs text-slate-400 uppercase tracking-wider">Population</p>
          <p class="text-white font-bold">{city.data.population}</p>
        </div>
        <div class="bg-[#2d5a3d] rounded-lg px-4 py-3">
          <p class="text-xs text-slate-400 uppercase tracking-wider">Median Home Price</p>
          <p class="text-white font-bold">{city.data.medianHomePrice}</p>
        </div>
        {city.data.distanceToGrandRapids && (
          <div class="bg-[#2d5a3d] rounded-lg px-4 py-3">
            <p class="text-xs text-slate-400 uppercase tracking-wider">From Grand Rapids</p>
            <p class="text-white font-bold">{city.data.distanceToGrandRapids}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <div class="max-w-6xl mx-auto px-4 py-12 grid md:grid-cols-3 gap-10">
    <!-- Main Content -->
    <div class="md:col-span-2">
      <div class="prose prose-slate max-w-none prose-headings:text-[#1a3a2a] prose-a:text-[#2d5a3d]">
        <Content />
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <!-- Agent Card -->
      {cityAgents.length > 0 && cityAgents.map(agent => (
        <div class="bg-white rounded-xl border border-slate-100 p-5 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-[#c9973a] mb-3">Your Local Expert</p>
          <div class="flex gap-3 items-start">
            <div class="w-12 h-12 rounded-full bg-slate-200 flex-shrink-0 overflow-hidden">
              <img src={agent.image} alt={agent.name} class="w-full h-full object-cover" onerror="this.style.display='none'" />
            </div>
            <div>
              <h3 class="font-bold text-[#1a3a2a]">{agent.name}</h3>
              <p class="text-sm text-slate-500">{agent.title} · {agent.brokerage}</p>
            </div>
          </div>
          <a href="/contact" class="block mt-4 bg-[#1a3a2a] text-[#f5f0e8] text-center py-2 rounded-md text-sm font-semibold hover:bg-[#2d5a3d] transition-colors">
            Contact {agent.name.split(' ')[0]}
          </a>
        </div>
      ))}

      {cityAgents.length === 0 && (
        <div class="bg-white rounded-xl border border-slate-100 p-5 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-[#c9973a] mb-3">Local Experts</p>
          <p class="text-sm text-slate-600 mb-4">Malcolm Wallaker and Bridger Hopkins serve {city.data.name} and all of northern Minnesota.</p>
          <a href="/agents" class="block bg-[#1a3a2a] text-[#f5f0e8] text-center py-2 rounded-md text-sm font-semibold hover:bg-[#2d5a3d] transition-colors">
            Meet Our Agents
          </a>
        </div>
      )}

      <!-- Quick Facts -->
      <div class="bg-[#f5f0e8] rounded-xl p-5">
        <h3 class="font-bold text-[#1a3a2a] mb-3">Why {city.data.name}?</h3>
        <p class="text-sm text-slate-600">{city.data.tagline}</p>
      </div>
    </aside>
  </div>
</Layout>
