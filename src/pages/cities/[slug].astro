---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { AGENTS } from '../../lib/constants';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map(city => ({ params: { slug: city.id }, props: { city } }));
}

const { city } = Astro.props;
const { Content } = await render(city);

const cityAgents = AGENTS.filter(a => a.cities.includes(city.data.name));

const schema = {
  '@type': 'WebPage',
  name: `${city.data.name}, MN Real Estate Guide`,
  description: city.data.tagline,
  about: {
    '@type': 'City',
    name: city.data.name,
    containedInPlace: { '@type': 'State', name: 'Minnesota' },
  },
};
---

<Layout
  title={`${city.data.name}, MN — Real Estate & Local Guide`}
  description={`${city.data.tagline}. Local real estate insights, school info, and community guides from Pemberton Real Estate's Malcolm Wallaker and Bridger Hopkins.`}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-[#1a3a2a] py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/cities" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white font-sans transition-colors mb-6">
        <span aria-hidden="true">←</span> All Cities
      </a>
      <span class="eyebrow text-[#c9973a]">Northern Minnesota</span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mt-2 mb-3">{city.data.name}, MN</h1>
      <p class="text-xl text-slate-300 font-sans font-light max-w-2xl">{city.data.tagline}</p>

      <!-- Stats -->
      <div class="flex flex-wrap gap-4 mt-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/10">
          <p class="text-xs text-slate-400 uppercase tracking-wider font-sans font-semibold">Population</p>
          <p class="text-white font-bold text-lg mt-0.5">{city.data.population}</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/10">
          <p class="text-xs text-slate-400 uppercase tracking-wider font-sans font-semibold">Median Home Price</p>
          <p class="text-white font-bold text-lg mt-0.5">{city.data.medianHomePrice}</p>
        </div>
        {city.data.distanceToGrandRapids && (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/10">
            <p class="text-xs text-slate-400 uppercase tracking-wider font-sans font-semibold">From Grand Rapids</p>
            <p class="text-white font-bold text-lg mt-0.5">{city.data.distanceToGrandRapids}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 grid md:grid-cols-3 gap-10">

    <!-- Main Content -->
    <div class="md:col-span-2">
      <div class="article-prose">
        <Content />
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-5">

      <!-- Agent Card -->
      {cityAgents.length > 0 ? cityAgents.map(agent => (
        <div class="card p-5">
          <span class="eyebrow">Your Local Expert</span>
          <div class="flex gap-3 items-center mt-1">
            <div class="w-14 h-14 rounded-full bg-slate-100 flex-shrink-0 overflow-hidden">
              <img src={agent.image} alt={agent.name} class="w-full h-full object-cover"
                onerror="this.parentElement.style.background='#e8e4dc'" />
            </div>
            <div>
              <h3 class="font-bold text-[#1a3a2a]">{agent.name}</h3>
              <p class="text-xs text-slate-500 font-sans">{agent.title} · {agent.brokerage}</p>
            </div>
          </div>
          <a href="/contact" class="btn-primary w-full text-center mt-4 text-sm py-2.5 block rounded-xl">
            Contact {agent.name.split(' ')[0]}
          </a>
        </div>
      )) : (
        <div class="card p-5">
          <span class="eyebrow">Local Experts</span>
          <p class="text-sm text-slate-600 font-sans mt-2 mb-4 leading-relaxed">
            Malcolm Wallaker and Bridger Hopkins serve {city.data.name} and all of northern Minnesota.
          </p>
          <a href="/agents" class="btn-primary w-full text-center text-sm py-2.5 block rounded-xl">
            Meet Our Agents
          </a>
        </div>
      )}

      <!-- Quick Facts -->
      <div class="bg-[#f5f0e8] rounded-2xl p-5">
        <h3 class="font-bold text-[#1a3a2a] mb-2">Why {city.data.name}?</h3>
        <p class="text-sm text-slate-600 font-sans leading-relaxed">{city.data.tagline}</p>
      </div>

      <!-- Quick links -->
      <div class="card p-5">
        <h3 class="font-bold text-[#1a3a2a] text-sm mb-3">Explore More</h3>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-sm text-[#2d5a3d] hover:underline font-sans font-medium">Real Estate Blog →</a></li>
          <li><a href="/news" class="text-sm text-[#2d5a3d] hover:underline font-sans font-medium">Local News →</a></li>
          <li><a href="/contact" class="text-sm text-[#2d5a3d] hover:underline font-sans font-medium">Contact an Agent →</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>
