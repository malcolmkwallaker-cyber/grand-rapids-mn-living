---
import Layout from '../../layouts/Layout.astro';
import { CITIES } from '../../lib/constants';
---

<Layout
  title="Northern Minnesota City Guides"
  description="Explore city guides for Grand Rapids, Hibbing, Virginia, Duluth, and 9 more northern Minnesota communities. Local real estate insights from Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate."
>
  <section class="bg-[#1a3a2a] py-14 px-4 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-[#c9973a] mb-3">Northern Minnesota</p>
    <h1 class="text-4xl font-bold text-white mb-4">City Guides</h1>
    <p class="text-slate-300 max-w-xl mx-auto">
      Detailed local guides for every community we serve — real estate market data, schools, lifestyle, and why our agents love living and working here.
    </p>
  </section>

  <section class="py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {CITIES.map(city => (
          <a
            href={`/cities/${city.slug}`}
            class="bg-white rounded-xl border border-slate-100 p-6 hover:shadow-md transition-shadow group"
          >
            <div class="flex items-start justify-between">
              <div>
                <h2 class="text-lg font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] transition-colors">
                  {city.name}, MN
                </h2>
                <p class="text-sm text-slate-400 mt-1">{city.county} County</p>
              </div>
              {city.primary && (
                <span class="text-xs bg-[#c9973a] text-white px-2 py-1 rounded font-semibold">Primary Market</span>
              )}
            </div>
            <p class="text-sm text-[#2d5a3d] mt-4 font-medium">Explore guide →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Agent CTA -->
  <section class="py-12 px-4 bg-[#f5f0e8] text-center">
    <h2 class="text-2xl font-bold text-[#1a3a2a] mb-3">Looking to Buy or Sell in Any of These Areas?</h2>
    <p class="text-slate-600 mb-6 max-w-lg mx-auto">
      Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate are the local experts for all 13 communities we serve.
    </p>
    <a href="/contact" class="bg-[#1a3a2a] text-[#f5f0e8] px-6 py-3 rounded-md font-semibold hover:bg-[#2d5a3d] transition-colors">
      Contact Our Agents
    </a>
  </section>
</Layout>
