---
import Layout from '../../layouts/Layout.astro';
import { CITIES } from '../../lib/constants';
---

<Layout
  title="Northern Minnesota City Guides"
  description="Explore city guides for Grand Rapids, Hibbing, Virginia, Duluth, and 9 more northern Minnesota communities. Local real estate insights from Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate."
>
  <!-- Hero -->
  <section class="relative h-[340px] overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1920&q=80"
      alt="Northern Minnesota"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-[#1e3a5f]/80"></div>
    <div class="relative h-full flex items-center justify-center text-center px-4">
      <div>
        <span class="eyebrow text-[#c9973a]">Northern Minnesota</span>
        <h1 class="text-5xl font-extrabold text-white mt-2 mb-4 tracking-tight">City Guides</h1>
        <p class="text-white/70 max-w-xl mx-auto text-lg">
          Detailed local guides for every community we serve — real estate data, schools, and what makes each place special.
        </p>
      </div>
    </div>
  </section>

  <!-- City Photo Grid -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5">
      {CITIES.map(city => (
        <a href={`/cities/${city.slug}`}
          class="group relative overflow-hidden rounded-xl bg-slate-900 aspect-[4/3] block shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <img
            src={city.photo}
            alt={`${city.name}, Minnesota`}
            class="absolute inset-0 w-full h-full object-cover opacity-75 group-hover:opacity-60 group-hover:scale-105 transition-all duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="text-xs font-bold uppercase tracking-widest text-[#c9973a] mb-1">Minnesota</p>
            <h2 class="text-xl font-extrabold text-white tracking-tight">{city.name}</h2>
            <p class="text-sm text-white/60 mt-1 font-medium group-hover:text-white transition-colors">
              Explore guide <span aria-hidden="true">→</span>
            </p>
          </div>
          {city.primary && (
            <div class="absolute top-3 right-3">
              <span class="text-xs bg-[#c9973a] text-white px-2 py-1 rounded font-bold uppercase tracking-wider">Primary</span>
            </div>
          )}
        </a>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <section class="bg-[#1e3a5f] py-16 px-4 text-center">
    <h2 class="text-3xl font-extrabold text-white mb-3 tracking-tight">Looking to Buy or Sell?</h2>
    <p class="text-white/70 mb-7 max-w-lg mx-auto">
      Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate are the local experts across all 13 communities.
    </p>
    <a href="/contact" class="bg-[#c9973a] text-white px-8 py-3.5 rounded-md font-bold hover:bg-[#b8832e] transition-all duration-200 text-sm">
      Contact Our Agents
    </a>
  </section>
</Layout>
