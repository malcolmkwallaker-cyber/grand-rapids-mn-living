---
import Layout from '../../layouts/Layout.astro';
import { CITIES } from '../../lib/constants';
---

<Layout
  title="Northern Minnesota City Guides"
  description="Explore city guides for Grand Rapids, Hibbing, Virginia, Duluth, and 9 more northern Minnesota communities. Local real estate insights from Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate."
>
  <!-- Hero -->
  <section class="bg-[#1a3a2a] py-16 px-4 text-center">
    <span class="eyebrow text-[#c9973a]">Northern Minnesota</span>
    <h1 class="text-5xl font-bold text-white mt-2 mb-4">City Guides</h1>
    <p class="text-slate-300 max-w-xl mx-auto font-sans font-light text-lg">
      Detailed local guides for every community we serve — real estate data, schools, lifestyle, and what makes each place special.
    </p>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5">
      {CITIES.map(city => (
        <a href={`/cities/${city.slug}`}
          class="card p-6 hover:-translate-y-0.5 transition-all duration-200 group">
          <!-- Accent bar -->
          <div class="w-6 h-0.5 bg-[#c9973a] rounded mb-4"></div>
          <div class="flex items-start justify-between">
            <div>
              <h2 class="text-lg font-bold text-[#1a3a2a] group-hover:text-[#2d5a3d] transition-colors">
                {city.name}
              </h2>
              <p class="text-xs text-slate-400 font-sans mt-0.5">Minnesota · {city.county} County</p>
            </div>
            {city.primary && (
              <span class="text-xs bg-amber-50 text-[#c9973a] border border-amber-200 px-2 py-0.5 rounded-full font-semibold font-sans flex-shrink-0 ml-2">
                Primary
              </span>
            )}
          </div>
          <p class="text-sm text-[#2d5a3d] mt-4 font-semibold font-sans group-hover:underline">Explore guide →</p>
        </a>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <section class="bg-[#f5f0e8] py-14 px-4 text-center">
    <h2 class="text-3xl font-bold text-[#1a3a2a] mb-3">Looking to Buy or Sell?</h2>
    <p class="text-slate-600 mb-7 max-w-lg mx-auto font-sans">
      Malcolm Wallaker and Bridger Hopkins at Pemberton Real Estate are the local experts across all 13 communities.
    </p>
    <a href="/contact" class="btn-primary">Contact Our Agents</a>
  </section>
</Layout>
